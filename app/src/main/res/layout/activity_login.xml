<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroundvk"
    android:orientation="vertical"
    android:padding="8dp"
    tools:context=".principal.ui.MainActivity">

    <RelativeLayout
        android:id="@+id/progress_login"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:indeterminate="true" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="39dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="81dp"
            android:layout_height="34dp"
            app:srcCompat="@drawable/logoarenaplan" />

        <TextView
            android:id="@+id/texttitulologin"
            android:layout_width="123dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=" Login"
            android:textColor="#2E7D32"
            android:textSize="20sp"
            tools:text=" Login" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="172dp"
            android:layout_height="45dp"
            android:layout_weight="2"
            android:background="#8FF379"
            android:text="Informe corretamente"
            android:textColor="#F8000000"
            android:textSize="18sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:outlineAmbientShadowColor="@color/teal_200">

        <TextView
            android:id="@+id/UsuarioTexto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:singleLine="false"
            android:text="Usuário:"
            android:textColor="#000000"
            android:textSize="24sp" />

        <EditText
            android:id="@+id/edUsuarioLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:enabled="true"
            android:focusable="false"
            android:hint="Usuário:"
            android:inputType="text"
            android:singleLine="true"
            android:textSize="24sp" />


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:outlineAmbientShadowColor="@color/teal_200">

        <TextView
            android:id="@+id/UsuarioTela"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:inputType="text"
            android:singleLine="false"
            android:text="Senha:"
            android:textColor="#000000"
            android:textSize="24sp" />

        <EditText
            android:id="@+id/edSenhaAcesso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:inputType="numberPassword"
            android:hint="Senha:"
            android:singleLine="false"
            android:textSize="24sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:outlineAmbientShadowColor="@color/teal_200"
        android:visibility="gone">

        <Spinner
            android:id="@+id/x_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1" />


    </LinearLayout>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnLogin"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="125dp"
            android:layout_height="90dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:drawableTop="@drawable/money1"
            android:insetTop="8dp"
            android:text="Login"
            android:textSize="16sp"
            android:visibility="visible"
            app:backgroundTint="#4CAF50"
            app:elevation="0dp"
            app:iconTint="#FFFFFF"
            app:strokeColor="#070707"
            tools:visibility="visible" />

        <Button
            android:id="@+id/buttonCancelar"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="95dp"
            android:layout_height="83dp"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:drawableTop="@android:drawable/ic_menu_close_clear_cancel"
            android:insetTop="0dp"
            android:text="Sair"
            android:textSize="16sp"
            android:visibility="visible"
            app:backgroundTint="#F30A0A"
            app:elevation="0dp"
            app:iconTint="#FFFFFF"
            app:strokeColor="#F9A825"
            tools:visibility="visible" />


        <Button
            android:id="@+id/btnSetupLogin"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="95dp"
            android:layout_height="89dp"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:drawableTop="@drawable/outrasopcoes"
            android:text="Setup"
            android:inputType="number"
            android:textSize="12sp"
            android:visibility="visible"
            app:backgroundTint="#1EF806"
            app:elevation="0dp"
            app:iconTint="#FFFFFF"
            app:strokeColor="#F9A825"
            tools:insetTop="5dp" />


    </LinearLayout>

</LinearLayout>

