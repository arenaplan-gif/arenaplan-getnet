<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroundvk"
    android:orientation="vertical"
    android:padding="8dp"
    >

    <RelativeLayout
        android:id="@+id/progress_setUp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:indeterminate="true" />
    </RelativeLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="39dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="81dp"
            android:layout_height="34dp"
            app:srcCompat="@drawable/logoarenaplan" />

        <TextView
            android:id="@+id/textViewopcoescaixa"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Setup"
            android:textColor="#2E7D32"
            android:textSize="20sp"
            tools:text="  Setup" />

        <TextView
            android:id="@+id/tvDataHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hora"
            android:textAlignment="center"
            android:textColor="#000000"
            android:textSize="10sp"
            android:visibility="visible"
            tools:text="12/05/2021\n11:00:01" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="172dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#8FF379"
            android:text="Preencha corretamente"
            android:textColor="#F8000000"
            android:textSize="18sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"

        android:outlineAmbientShadowColor="@color/teal_200">

        <TextView
            android:id="@+id/UsuarioTexto"
            android:layout_width="378dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:inputType="number"
            android:singleLine="false"
            android:text="Código da Máquina:"
            android:textColor="#000000"
            android:textSize="24sp" />

        <EditText
            android:id="@+id/edCodigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:hint="Código"
            android:inputType="number"
            android:singleLine="false"
            android:textSize="24sp"
            tools:text="Código" />


    </LinearLayout>



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:outlineAmbientShadowColor="@color/teal_200">

        <TextView
            android:id="@+id/usuarioTela"
            android:layout_width="191dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:inputType="number"
            android:singleLine="false"
            android:text="Usuário:"
            android:textColor="#000000"
            android:textSize="24sp" />

        <EditText
            android:id="@+id/edUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Usuário"
            android:inputType="text"
            android:singleLine="false"
            android:textSize="24sp"
            tools:text="Usuário" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"

        android:outlineAmbientShadowColor="@color/teal_200">

        <TextView
            android:id="@+id/textVIewIdFiscal"
            android:layout_width="382dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:inputType="number"
            android:singleLine="false"
            android:text="Id Fiscal:"
            android:textColor="#000000"
            android:textSize="24sp" />

        <EditText
            android:id="@+id/edIdFiscal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:inputType="number"
            android:singleLine="false"
            android:text="0"
            android:textSize="24sp" />


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:outlineAmbientShadowColor="@color/teal_200">

        <TextView
            android:id="@+id/senhaUsurio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#000000"
            android:ems="10"
            android:inputType="number"
            android:singleLine="false"
            android:text="Senha:" />

        <EditText
            android:id="@+id/edSenha"
            android:layout_width="183dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:hint="Senha"
            android:inputType="textPassword"
            android:singleLine="false"
            />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:outlineAmbientShadowColor="@color/teal_200">

        <TextView
            android:id="@+id/UsuarioTela"
            android:layout_width="376dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:inputType="number"
            android:singleLine="false"
            android:text="Tipo de Recibo:"
            android:textColor="#000000"
            android:textSize="24sp" />

        <Spinner
            android:id="@+id/x_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/tipo_recibo"
            android:layout_weight="1" />


    </LinearLayout>


    <LinearLayout
        android:id="@+id/view_senha_offline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:outlineAmbientShadowColor="@color/teal_200">

        <TextView
            android:id="@+id/senhaOfficeLine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#000000"
            android:ems="10"
            android:inputType="number"
            android:singleLine="false"
            android:text="Senha Offline:" />

        <EditText
            android:id="@+id/edSenhaOffline"
            android:layout_width="183dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:hint="Senha Offline"
            android:inputType="textPassword"
            android:singleLine="false"
            />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="29dp"
        android:orientation="horizontal"
        android:visibility="gone"
        android:outlineAmbientShadowColor="@color/teal_200" />


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/login"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="125dp"
            android:layout_height="90dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:drawableTop="@drawable/outrasopcoes"
            android:text="Confirmar"
            android:textSize="12sp"
            android:visibility="visible"
            app:backgroundTint="#4CAF50"
            app:elevation="0dp"
            app:iconTint="#FFFFFF"
            app:strokeColor="#070707"
            tools:onClick="@"
            tools:visibility="visible" />

        <Button
            android:id="@+id/buttonCancelar"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="105dp"
            android:layout_height="83dp"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:drawableTop="@android:drawable/ic_menu_close_clear_cancel"
            android:insetTop="0dp"
            android:onClick="Encerrar"
            android:text="Encerrar"
            android:textSize="12sp"
            android:visibility="visible"
            app:backgroundTint="#F80619"
            app:elevation="2dp"
            app:iconTint="#FFFFFF"
            app:strokeColor="#F9A825" />


    </LinearLayout>



</LinearLayout>

