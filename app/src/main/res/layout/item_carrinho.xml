<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:padding="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="4dp"
    app:cardElevation="4dp"
    android:layout_height="wrap_content">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvCodigoProduto"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="1dp"
            android:textColor="#F7000000"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="000001" />

        <TextView
            android:id="@+id/tvNomeProduto"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:textColor="#F7000000"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvCodigoProduto"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="COCA COLA ZE" />

        <TextView
            android:id="@+id/tvQuantidade"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="#F7000000"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvNomeProduto"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="x2" />

        <TextView
            android:id="@+id/tvUnidade"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:textColor="#F7000000"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvQuantidade"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="UN" />

        <TextView
            android:id="@+id/tvValorUnitario"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:textColor="#F7000000"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tvValorTotal"
            app:layout_constraintStart_toEndOf="@+id/tvUnidade"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="R$ 20,00" />

        <TextView
            android:id="@+id/tvValorTotal"
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:textColor="#F7000000"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/buttonCancelar"
            app:layout_constraintStart_toEndOf="@+id/tvValorUnitario"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="R$ 80,00" />

        <ImageButton
            android:id="@+id/buttonCancelar"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="4dp"
            android:padding="8dp"
            android:src="@drawable/ic_baseline_cancel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>



</androidx.cardview.widget.CardView>