<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="4dp"
    xmlns:tools="http://schemas.android.com/tools">



   <androidx.constraintlayout.widget.ConstraintLayout
       android:layout_margin="4dp"
       android:layout_width="match_parent"
       android:layout_height="wrap_content">

    <TextView
        android:id="@+id/textViewCodigo"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:textColor="#F7000000"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="000001" />

    <TextView
        android:id="@+id/textNomeProduto"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="#F7000000"
        android:textSize="18sp"
        app:layout_constraintStart_toEndOf="@+id/textViewCodigo"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="COCA COLA" />

    <TextView
        android:id="@+id/textValorUnitario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:textColor="#F7000000"
        android:textSize="18sp"
        app:layout_constraintStart_toEndOf="@+id/textNomeProduto"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="R$ 4,00" />
   </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

