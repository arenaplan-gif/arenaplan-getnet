<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/headerInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONSUMO DA MESA/COMANDA"
            android:textColor="#2E7D32"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvMesaLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mesa: "
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/NumeroMesa"
                android:layout_toEndOf="@id/tvMesaLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09"
                android:textSize="18sp"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/totaldamesa"
                android:layout_alignParentEnd="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 0,00"
                android:textColor="#D32F2F"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutAcoes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerInfo">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonImprimir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Imprimir"
            app:backgroundTint="#4CAF50"
            app:icon="@android:drawable/ic_menu_agenda" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonEncerrar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Fechar Mesa"
            app:backgroundTint="#1976D2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSair"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sair"
            app:backgroundTint="#D32F2F" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tableHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EEEEEE"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutAcoes">
        <TextView android:layout_width="35dp" android:layout_height="wrap_content" android:text="Cod" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Produto" android:textStyle="bold"/>
        <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="Qtde" android:gravity="center" android:textStyle="bold"/>
        <TextView android:layout_width="70dp" android:layout_height="wrap_content" android:text="Valor" android:gravity="end" android:textStyle="bold"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvConsumo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/textobs"
        app:layout_constraintTop_toBottomOf="@id/tableHeader" />

    <TextView
        android:id="@+id/textobs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:text="Obs: Consumo efetuado até este momento."
        android:textAlignment="center"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>