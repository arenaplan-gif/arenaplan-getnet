<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroundvk"
    android:orientation="vertical"
    android:padding="8dp"
    tools:context=".principal.ui.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="39dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="81dp"
            android:layout_height="34dp"
            app:srcCompat="@drawable/logoarenaplan" />

        <TextView
            android:id="@+id/texttitulosetup"
            android:layout_width="123dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="fff"
            android:textColor="#2E7D32"
            android:textSize="20sp"
            tools:text="  Setup" />

        <TextView
            android:id="@+id/textView11"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hora"
            android:textColor="#000000"
            android:textSize="10sp"
            tools:text="12/05/2021\n11:00:01" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="172dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#8FF379"
            android:text="Preencha corretamente"
            android:textColor="#F8000000" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:orientation="horizontal"
        android:outlineAmbientShadowColor="@color/teal_200">

        <TextView
            android:id="@+id/UsuarioTexto"
            android:layout_width="188dp"
            android:textColor="#000000"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:inputType="number"
            android:singleLine="false"
            tools:text="Código da Máquina" />
        <EditText
            android:id="@+id/edtCodigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:inputType="number"
            android:singleLine="false"
            tools:text="Código" />
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:outlineAmbientShadowColor="@color/teal_200">

        <TextView
            android:id="@+id/usuarioTela"
            android:layout_width="108dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:inputType="number"
            android:singleLine="false"
            android:textColor="#000000"
            tools:text="Usuário:" />

        <EditText
            android:id="@+id/SenhaTela"
            android:layout_width="183dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:inputType="number"
            android:singleLine="false"
            tools:text="Usuário" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:outlineAmbientShadowColor="@color/teal_200">

        <TextView
            android:id="@+id/UsuarioTela"
            android:layout_width="376dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ems="10"
            android:textColor="#000000"
            android:inputType="number"
            android:singleLine="false"
            tools:text="Tipo de Recibo:" />

        <Spinner
            android:id="@+id/x_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1" />


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="29dp"
        android:orientation="horizontal"
        android:outlineAmbientShadowColor="@color/teal_200" />


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/login"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="205dp"
            android:layout_height="45dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:background="@drawable/layout_shape"
            android:text="Confirmar"
            android:textSize="12sp"
            android:visibility="visible"
            app:backgroundTint="#4CAF50"
            app:elevation="2dp"
            app:icon="@drawable/layout_shape"
            app:iconTint="#FFFFFF"
            app:strokeColor="#070707"
            tools:visibility="visible" />

        <Button
            android:id="@+id/button3"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="120dp"
            android:layout_height="45dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:insetTop="2dp"
            android:text="Cancel"
            android:textSize="12sp"
            android:visibility="visible"
            app:backgroundTint="#F80619"
            app:elevation="2dp"
            app:icon="@drawable/cancel"
            app:iconTint="#FFFFFF"
            app:strokeColor="#F9A825" />


    </LinearLayout>

</LinearLayout>

