<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/opcoes_do_caixa"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroundvk"
    android:orientation="vertical"
    android:padding="8dp"
   >

    <RelativeLayout
        android:id="@+id/progressOpcoesCaixa"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:indeterminate="true" />
    </RelativeLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="39dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="81dp"
            android:layout_height="34dp"
            app:srcCompat="@drawable/logoarenaplan" />

        <TextView
            android:id="@+id/texttituloopcaocaixa"
            android:layout_width="123dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Opcoes_caixa"
            android:textColor="#2E7D32"
            android:textSize="20sp"
            tools:text="Opções do Caixa" />

        <TextView
            android:id="@+id/textView11"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hora"
            android:textColor="#000000"
            android:textSize="10sp"
            tools:text="12/05/2021\n11:00:01" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="136dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#8FF379"
            android:text="Selecione opção"
            android:textColor="#F8000000" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="105dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonAbrirCaixa"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="155dp"
            android:layout_height="85dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:background="@drawable/rounded_corner"
            android:insetLeft="1dp"
            android:insetTop="2dp"
            android:insetRight="1dp"
            android:text="Abrir o Caixa"
            android:textSize="12sp"
            android:visibility="visible"
            app:backgroundTint="#4CAF50"
            app:elevation="2dp"
            app:icon="@drawable/cancel2_icon_24px"
            app:iconTint="#FFFFFF"
            app:strokeColor="#070707"
            tools:visibility="visible" />

        <Button
            android:id="@+id/buttonFechaCaixa"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="155dp"
            android:layout_height="85dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:background="@drawable/rounded_corner"
            android:insetLeft="1dp"
            android:insetTop="2dp"
            android:text="Fechar o Caixa"
            android:textSize="12sp"
            android:visibility="visible"
            app:backgroundTint="#4BE612"
            app:elevation="2dp"
            app:icon="@drawable/calculator_icon_24px"
            app:iconTint="#FFFFFF"
            app:strokeColor="#070707"
            tools:visibility="visible" />


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="105dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btStatusCaixa"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="155dp"
            android:layout_height="85dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:insetTop="2dp"
            android:text="Status do Caixa"
            android:textSize="12sp"
            android:visibility="visible"
            app:backgroundTint="#6BCF68"
            app:elevation="2dp"
            app:icon="@drawable/print2_icon_24px"
            app:iconTint="#FFFFFF"
            app:strokeColor="#F9A825" />


    </LinearLayout>


</LinearLayout>